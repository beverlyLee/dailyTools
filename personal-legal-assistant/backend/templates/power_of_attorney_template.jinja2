{% if authorization_scope and authorization_scope is iterable and authorization_scope is not string %}
{% for scope in authorization_scope %}
{{ loop.index }}. {{ scope }}
{% endfor %}
{% else %}
{{ authorization_scope|default('一般代理') }}
