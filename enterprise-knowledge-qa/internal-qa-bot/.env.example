# 应用配置
APP_NAME=企业知识库与问答助手
DEBUG=true
VERSION=1.0.0

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 向量数据库配置
CHROMA_DB_PATH=./data/vector_store
CHROMA_COLLECTION_NAME=enterprise_knowledge

# 嵌入模型配置
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_MODEL_DEVICE=cpu

# LLM配置
LLM_TYPE=local  # 可选: local, openai
# 如果使用本地LLM
LOCAL_LLM_PATH=./models/llm-model.gguf
LOCAL_LLM_TEMPERATURE=0.7
LOCAL_LLM_MAX_TOKENS=1024
# 如果使用OpenAI
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL_NAME=gpt-3.5-turbo

# 文档处理配置
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
