# 植物病害识别系统 - 环境变量配置文件
# 复制此文件为 .env 并根据实际情况修改配置

# API 配置
API_V1_STR=/api/v1
PROJECT_NAME=植物病害识别系统

# 数据库配置
# SQLite 数据库路径
DATABASE_URL=sqlite:///./plant_disease.db

# 模型配置
# 模型文件路径（支持 .pt 或 .onnx 格式）
MODEL_PATH=./models/plant_disease_model.pt
# 模型格式: pt (PyTorch) 或 onnx
MODEL_FORMAT=pt

# 图片处理配置
# 输入图片尺寸
IMAGE_SIZE=224
# 归一化均值
NORMALIZE_MEAN=[0.485, 0.456, 0.406]
# 归一化标准差
NORMALIZE_STD=[0.229, 0.224, 0.225]
