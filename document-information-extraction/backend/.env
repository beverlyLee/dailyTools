# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invoice_db

# JWT配置
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OCR模型配置
OCR_MODEL_PATH=

# 财税校验API配置 (mock 或 实际API地址)
TAX_VERIFICATION_API=mock

# 公司名称 (用于发票抬头校验)
COMPANY_NAME=某某有限公司
