<UserControl x:Class="DigitalFactoryTwin.Views.ApsOptimizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1400">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="White" Padding="15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📊 APS 排程优化" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#333333"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="🔄 刷新" 
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,10,0"/>
                    <Button Content="📦 物料齐套检查" 
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding CheckMaterialsCommand}"
                            Background="#FF9800"
                            Margin="0,0,10,0"/>
                    <Button Content="⚡ 执行排程" 
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding RunSchedulingCommand}"
                            IsEnabled="{Binding IsScheduling, Converter={StaticResource InverseBoolConverter}}"
                            Background="#4CAF50"
                            Margin="0,0,10,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                            <StackPanel>
                                <TextBlock Text="待排程订单" FontWeight="Bold" Foreground="#666666"/>
                                <TextBlock Text="{Binding PendingOrders.Count, StringFormat='共 {0} 个订单'}" FontSize="11" Foreground="#999999" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <ListView Grid.Row="1" 
                                  ItemsSource="{Binding PendingOrders}"
                                  SelectedItem="{Binding SelectedOrder}"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="5" 
                                            BorderBrush="#E0E0E0" BorderThickness="1" 
                                            CornerRadius="4"
                                            Background="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding OrderId}" FontWeight="Bold" FontSize="12"/>
                                                <TextBlock Text="{Binding Product.ProductName}" FontSize="11" Foreground="#666666"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="数量: " FontSize="10" Foreground="#999999"/>
                                                    <TextBlock Text="{Binding Quantity}" FontSize="10" Foreground="#333333"/>
                                                    <TextBlock Text="  优先级: " FontSize="10" Foreground="#999999" Margin="5,0,0,0"/>
                                                    <TextBlock Text="{Binding Priority}" FontSize="10" FontWeight="Bold" Foreground="#F44336"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="交货期" FontSize="10" Foreground="#999999"/>
                                                <TextBlock Text="{Binding DueDate, StringFormat='MM-dd HH:mm'}" FontSize="11" FontWeight="Bold" Foreground="#FF9800"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
                
                <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                            <StackPanel>
                                <TextBlock Text="排程历史" FontWeight="Bold" Foreground="#666666"/>
                                <TextBlock Text="{Binding ScheduleRuns.Count, StringFormat='共 {0} 次排程'}" FontSize="11" Foreground="#999999" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <ListView Grid.Row="1" 
                                  ItemsSource="{Binding ScheduleRuns}"
                                  SelectedItem="{Binding SelectedScheduleRun}"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="5" 
                                            BorderBrush="#E0E0E0" BorderThickness="1" 
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding RunName}" FontWeight="Bold" FontSize="12"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}" FontSize="10" Foreground="#999999"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="工期: " FontSize="10" Foreground="#999999"/>
                                                    <TextBlock Text="{Binding ResultMakespan, StringFormat='{0:F0} 分钟'}" FontSize="10" Foreground="#333333"/>
                                                    <TextBlock Text="  延期: " FontSize="10" Foreground="#999999" Margin="5,0,0,0"/>
                                                    <TextBlock Text="{Binding ResultLateOrders, StringFormat='{0} 单'}" FontSize="10" 
                                                               Foreground="{Binding ResultLateOrders, Converter={StaticResource LateOrdersToColorConverter}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding StatusDisplayName}" 
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="completed">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="failed">
                                                                <Setter Property="Foreground" Value="#F44336"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="running">
                                                                <Setter Property="Foreground" Value="#2196F3"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
            
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Background="#2196F3" CornerRadius="4" Padding="10,5" Margin="0,0,15,0">
                                <StackPanel>
                                    <TextBlock Text="排程状态" FontSize="10" Foreground="#BBDEFB"/>
                                    <TextBlock Text="{Binding SchedulingStatus}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#4CAF50" CornerRadius="4" Padding="10,5" Margin="0,0,15,0">
                                <StackPanel>
                                    <TextBlock Text="待排订单" FontSize="10" Foreground="#C8E6C9"/>
                                    <TextBlock Text="{Binding PendingOrders.Count}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#FF9800" CornerRadius="4" Padding="10,5" Margin="0,0,15,0">
                                <StackPanel>
                                    <TextBlock Text="已排订单" FontSize="10" Foreground="#FFE0B2"/>
                                    <TextBlock Text="{Binding ScheduledOrders.Count}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="📊 甘特图" 
                                    Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding ViewGanttChartCommand}"
                                    IsEnabled="{Binding SelectedScheduleRun, Converter={StaticResource NullToBoolConverter}, ConverterParameter='False'}"
                                    Background="#9C27B0"
                                    Margin="0,0,10,0"/>
                            <Button Content="📈 资源负荷" 
                                    Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding ViewResourceLoadCommand}"
                                    IsEnabled="{Binding SelectedScheduleRun, Converter={StaticResource NullToBoolConverter}, ConverterParameter='False'}"
                                    Background="#00BCD4"
                                    Margin="0,0,10,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="算法参数设置" FontWeight="Bold" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="种群大小: " VerticalAlignment="Center" Foreground="#666666"/>
                                    <TextBox Text="{Binding PopulationSize}" Width="60" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="迭代次数: " VerticalAlignment="Center" Foreground="#666666"/>
                                    <TextBox Text="{Binding Generations}" Width="60" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="变异概率: " VerticalAlignment="Center" Foreground="#666666"/>
                                    <TextBox Text="{Binding MutationProb}" Width="60" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="交叉概率: " VerticalAlignment="Center" Foreground="#666666"/>
                                    <TextBox Text="{Binding CrossoverProb}" Width="60" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="优化目标: " VerticalAlignment="Center" Foreground="#666666" Margin="0,0,10,0"/>
                                <ComboBox Width="180" 
                                          ItemsSource="{Binding Objectives}"
                                          SelectedItem="{Binding SelectedObjective}"
                                          IsSynchronizedWithCurrentItem="True">
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <Border Grid.Row="1" Background="White" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                                <TextBlock Text="排程作业列表" FontWeight="Bold" Foreground="#666666"/>
                            </Border>
                            
                            <ListView Grid.Row="1" 
                                      ItemsSource="{Binding ScheduleJobs}"
                                      BorderThickness="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10" Margin="5" 
                                                BorderBrush="#E0E0E0" BorderThickness="1" 
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding JobId}" FontWeight="Bold" FontSize="12"/>
                                                    <TextBlock Text="{Binding ProcessStep.StepName}" FontSize="11" Foreground="#666666"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <TextBlock Text="订单: " FontSize="10" Foreground="#999999"/>
                                                        <TextBlock Text="{Binding Order.OrderId}" FontSize="10" Foreground="#333333"/>
                                                        <TextBlock Text="  工作中心: " FontSize="10" Foreground="#999999" Margin="5,0,0,0"/>
                                                        <TextBlock Text="{Binding WorkCenter.WorkCenterName}" FontSize="10" Foreground="#333333"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding StatusDisplayName}" 
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Right">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="scheduled">
                                                                        <Setter Property="Foreground" Value="#2196F3"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="in_progress">
                                                                        <Setter Property="Foreground" Value="#FF9800"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="completed">
                                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="delayed">
                                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding PlannedStartTime, StringFormat='HH:mm'}" FontSize="10" Foreground="#999999" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding PlannedEndTime, StringFormat='HH:mm'}" FontSize="10" Foreground="#666666" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                            <TextBlock Text="资源状态" FontWeight="Bold" Foreground="#666666"/>
                        </Border>
                        
                        <TabControl Grid.Row="1" BorderThickness="0">
                            <TabItem Header="工作中心">
                                <ListView ItemsSource="{Binding WorkCenters}" BorderThickness="0">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10" Margin="5" 
                                                    BorderBrush="#E0E0E0" BorderThickness="1" 
                                                    CornerRadius="4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding WorkCenterName}" FontWeight="Bold" FontSize="12"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="产能: " FontSize="10" Foreground="#999999"/>
                                                        <TextBlock Text="{Binding Capacity}" FontSize="10" Foreground="#333333"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </TabItem>
                            
                            <TabItem Header="模具">
                                <ListView ItemsSource="{Binding Molds}" BorderThickness="0">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10" Margin="5" 
                                                    BorderBrush="#E0E0E0" BorderThickness="1" 
                                                    CornerRadius="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding MoldName}" FontWeight="Bold" FontSize="12"/>
                                                        <TextBlock Text="{Binding MoldId}" FontSize="10" Foreground="#999999"/>
                                                        <ProgressBar Value="{Binding LifePercentage}" 
                                                                     Maximum="100" 
                                                                     Width="100" 
                                                                     Height="5" 
                                                                     Margin="0,5,0,0">
                                                            <ProgressBar.Style>
                                                                <Style TargetType="ProgressBar">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding LifePercentage}" Value="30">
                                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                    </StackPanel>
                                                    
                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding StatusDisplayName}" 
                                                               FontSize="10"
                                                               VerticalAlignment="Center"
                                                               FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="available">
                                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="in_use">
                                                                        <Setter Property="Foreground" Value="#FF9800"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </TabItem>
                            
                            <TabItem Header="员工">
                                <ListView ItemsSource="{Binding Employees}" BorderThickness="0">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10" Margin="5" 
                                                    BorderBrush="#E0E0E0" BorderThickness="1" 
                                                    CornerRadius="4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="技能等级: " FontSize="10" Foreground="#999999"/>
                                                        <TextBlock Text="{Binding SkillLevel}" FontSize="10" Foreground="#333333"/>
                                                        <TextBlock Text="  " FontSize="10"/>
                                                        <TextBlock Text="{Binding StatusDisplayName}" FontSize="10">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="available">
                                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="on_shift">
                                                                            <Setter Property="Foreground" Value="#FF9800"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
                
                <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                            <TextBlock Text="排程结果指标" FontWeight="Bold" Foreground="#666666"/>
                        </Border>
                        
                        <StackPanel Grid.Row="1" Margin="15">
                            <Border Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="总工期" FontSize="11" Foreground="#1976D2"/>
                                    <TextBlock Text="{Binding SelectedScheduleRun.ResultMakespan, StringFormat='{0:F0} 分钟', FallbackValue='- 分钟'}" 
                                               FontSize="24" 
                                               FontWeight="Bold" 
                                               Foreground="#1976D2"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#E8F5E9" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="资源利用率" FontSize="11" Foreground="#388E3C"/>
                                    <TextBlock Text="{Binding SelectedScheduleRun.ResultResourceUtilization, StringFormat='{0:F1} %', FallbackValue='- %'}" 
                                               FontSize="24" 
                                               FontWeight="Bold" 
                                               Foreground="#388E3C"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#FFF3E0" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="延期订单" FontSize="11" Foreground="#F57C00"/>
                                    <TextBlock Text="{Binding SelectedScheduleRun.ResultLateOrders, StringFormat='{0} 单', FallbackValue='- 单'}" 
                                               FontSize="24" 
                                               FontWeight="Bold" 
                                               Foreground="#F57C00"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#FCE4EC" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="总成本" FontSize="11" Foreground="#C2185B"/>
                                    <TextBlock Text="{Binding SelectedScheduleRun.ResultTotalCost, StringFormat='¥ {0:N0}', FallbackValue='¥ -'}" 
                                               FontSize="24" 
                                               FontWeight="Bold" 
                                               Foreground="#C2185B"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <Border Grid.Row="2" Background="#F8F9FA" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="状态: " Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SchedulingStatus}" 
                           FontWeight="Bold" 
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                
                <TextBlock Text="  |  待排订单: " Margin="20,0,5,0" Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding PendingOrders.Count}" FontWeight="Bold" Foreground="#FF9800" VerticalAlignment="Center"/>
                
                <TextBlock Text="  |  已排订单: " Margin="20,0,5,0" Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ScheduledOrders.Count}" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                
                <TextBlock Text="  |  排程历史: " Margin="20,0,5,0" Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ScheduleRuns.Count}" FontWeight="Bold" Foreground="#2196F3" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
