<UserControl x:Class="DigitalFactoryTwin.Views.ProductionLineMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1400">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="White" Padding="15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🏭 产线3D监控" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#333333"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ComboBox Width="200" 
                              Margin="0,0,10,0"
                              ItemsSource="{Binding ProductionLines}"
                              SelectedItem="{Binding SelectedProductionLine}"
                              DisplayMemberPath="LineName"
                              IsSynchronizedWithCurrentItem="True">
                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="10,5"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                    <Button Content="🔄 刷新" 
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,10,0"/>
                    <Button Content="📡 实时监控" 
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ToggleRealTimeMonitoringCommand}"
                            Background="{Binding IsRealTimeMonitoring, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4CAF50;#2196F3'}"
                            Margin="0,0,10,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                        <TextBlock Text="设备列表" FontWeight="Bold" Foreground="#666666"/>
                    </Border>
                    
                    <ListView Grid.Row="1" 
                              ItemsSource="{Binding ProductionLineDevices}"
                              SelectedItem="{Binding SelectedDevice}"
                              BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="5" 
                                        BorderBrush="#E0E0E0" BorderThickness="1" 
                                        CornerRadius="4"
                                        Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="⚙️" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DeviceName}" FontWeight="Bold" FontSize="13"/>
                                            <TextBlock Text="{Binding DeviceId}" FontSize="11" Foreground="#999999"/>
                                            <TextBlock Text="{Binding StatusDisplayName}" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="running">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="fault">
                                                                <Setter Property="Foreground" Value="#F44336"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="maintenance">
                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="stopped">
                                                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    
                    <Border Grid.Row="2" Background="#F8F9FA" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="设备总数: " Foreground="#666666"/>
                            <TextBlock Text="{Binding ProductionLineDevices.Count}" FontWeight="Bold" Foreground="#333333"/>
                            <TextBlock Text="  运行中: " Margin="10,0,0,0" Foreground="#666666"/>
                            <TextBlock Text="{Binding ProductionLineDevices.Count}" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            
            <Border Grid.Column="1" Background="#1A1A2E">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="Transparent" Padding="15,10">
                        <TextBlock Text="3D 工厂视图" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    </Border>
                    
                    <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="🏭" FontSize="80" HorizontalAlignment="Center"/>
                            <TextBlock Text="Unity 3D 视图区域" FontSize="18" Foreground="White" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                            <TextBlock Text="(将在此处集成 Unity 3D 引擎)" FontSize="12" Foreground="#888888" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            
                            <Border Margin="0,30,0,0" Padding="20" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="当前选中设备信息" FontSize="14" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedDevice.DeviceName, FallbackValue='未选择设备'}" 
                                               FontSize="16" Foreground="#2196F3" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                    <TextBlock Text="{Binding SelectedDevice.DeviceId, FallbackValue='-'}" 
                                               FontSize="12" Foreground="#888888" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding SelectedDevice.StatusDisplayName, FallbackValue='-'}" 
                                               FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedDevice.Status}" Value="running">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedDevice.Status}" Value="fault">
                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedDevice.Status}" Value="maintenance">
                                                        <Setter Property="Foreground" Value="#FF9800"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                    
                    <Border Grid.Row="2" Background="Transparent" Padding="15,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🔍 拆解查看" 
                                    Command="{Binding StartDisassemblyCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Margin="0,0,10,0"/>
                            <Button Content="⬅️ 上一步" 
                                    Command="{Binding PreviousDisassemblyStepCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Margin="0,0,10,0"/>
                            <Button Content="➡️ 下一步" 
                                    Command="{Binding NextDisassemblyStepCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Margin="0,0,10,0"/>
                            <Button Content="🔄 重置" 
                                    Command="{Binding ResetDisassemblyCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#FF9800"
                                    Margin="0,0,10,0"/>
                            <TextBlock Text="拆解步骤: " VerticalAlignment="Center" Foreground="White" Margin="20,0,5,0"/>
                            <TextBlock Text="{Binding CurrentDisassemblyStep, StringFormat={}{0} / 0}" 
                                       VerticalAlignment="Center" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                            <TextBlock Text="实时 PLC 数据" FontWeight="Bold" Foreground="#666666"/>
                        </Border>
                        
                        <ListView Grid.Row="1" 
                                  ItemsSource="{Binding RealTimePLCData}"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="5" 
                                            BorderBrush="#E0E0E0" BorderThickness="1" 
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding TagName}" FontWeight="Bold" FontSize="12"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" FontSize="10" Foreground="#999999"/>
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding TagValue}" 
                                                       FontWeight="Bold" 
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding Quality, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4CAF50;#F44336'}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
                
                <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                            <TextBlock Text="设备组件" FontWeight="Bold" Foreground="#666666"/>
                        </Border>
                        
                        <ListView Grid.Row="1" 
                                  ItemsSource="{Binding DeviceComponents}"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="5" 
                                            BorderBrush="#E0E0E0" BorderThickness="1" 
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" 
                                                       Text="🔧" 
                                                       FontSize="16" 
                                                       Margin="0,0,10,0" 
                                                       VerticalAlignment="Center"/>
                                            
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding ComponentName}" FontWeight="Bold" FontSize="12"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="拆解顺序: " FontSize="10" Foreground="#999999"/>
                                                    <TextBlock Text="{Binding DisassembleOrder}" FontSize="10" Foreground="#666666"/>
                                                    <TextBlock Text="  可拆解: " FontSize="10" Foreground="#999999" Margin="10,0,0,0"/>
                                                    <TextBlock Text="{Binding CanDisassemble, Converter={StaticResource BoolToYesNoConverter}}" 
                                                               FontSize="10" 
                                                               Foreground="{Binding CanDisassemble, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4CAF50;#9E9E9E'}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <Border Grid.Row="2" Background="#F8F9FA" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="状态: " Foreground="#666666" VerticalAlignment="Center"/>
                <Ellipse Width="8" Height="8" Fill="{Binding IsRealTimeMonitoring, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4CAF50;#9E9E9E'}" 
                         Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding IsRealTimeMonitoring, Converter={StaticResource BoolToEnabledDisabledConverter}}" 
                           Foreground="#333333" VerticalAlignment="Center"/>
                
                <TextBlock Text="  |  产线: " Margin="20,0,5,0" Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SelectedProductionLine.LineName, FallbackValue='未选择'}" 
                           FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
                
                <TextBlock Text="  |  设备: " Margin="20,0,5,0" Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SelectedDevice.DeviceName, FallbackValue='未选择'}" 
                           FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
