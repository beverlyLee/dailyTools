<UserControl x:Class="DigitalFactoryTwin.Views.DeviceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1400">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="White" Padding="15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="⚙️ 设备详情" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#333333"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="🔄 刷新" 
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0,0,10,0"/>
                    <Button Content="📷 3D 预览" 
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#9C27B0"
                            Margin="0,0,10,0"/>
                    <Button Content="🔍 拆解查看" 
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#00BCD4"
                            Margin="0,0,10,0"/>
                    <Button Content="📊 历史数据" 
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#FF9800"
                            Margin="0,0,10,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                        <TextBlock Text="设备基本信息" FontWeight="Bold" Foreground="#666666"/>
                    </Border>
                    
                    <StackPanel Grid.Row="1" Margin="15">
                        <Border Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="⚙️" FontSize="40" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="设备名称" FontSize="11" Foreground="#1976D2"/>
                                    <TextBlock Text="CNC-001 数控铣床" FontSize="18" FontWeight="Bold" Foreground="#1976D2" Margin="0,5,0,0"/>
                                    <TextBlock Text="设备编号: CNC-MILL-001" FontSize="12" Foreground="#666666" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <Border Background="#E8F5E9" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="设备类型" FontSize="11" Foreground="#388E3C"/>
                                    <TextBlock Text="数控机床" FontSize="14" FontWeight="Bold" Foreground="#388E3C" Margin="0,5,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="当前状态" FontSize="11" Foreground="#388E3C"/>
                                    <TextBlock Text="运行中" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <Border Background="#FFF3E0" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="位置" FontSize="11" Foreground="#F57C00"/>
                                    <TextBlock Text="车间 A - 生产线 1" FontSize="14" FontWeight="Bold" Foreground="#F57C00" Margin="0,5,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="负责人" FontSize="11" Foreground="#F57C00"/>
                                    <TextBlock Text="张工程师" FontSize="14" FontWeight="Bold" Foreground="#F57C00" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <Border Background="#FCE4EC" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="设备描述" FontSize="11" Foreground="#C2185B"/>
                                <TextBlock Text="高精度数控铣床，用于精密零件加工。支持多种材料加工，包括铝合金、钢材等。最大加工尺寸：500x400x300mm。" 
                                           FontSize="12" 
                                           Foreground="#C2185B" 
                                           Margin="0,5,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Text="设备参数" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,10,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="主轴转速" FontSize="11" Foreground="#999999"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="12,000 rpm" FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="进给速度" FontSize="11" Foreground="#999999"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="5,000 mm/min" FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="最大功率" FontSize="11" Foreground="#999999"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="15 kW" FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="精度" FontSize="11" Foreground="#999999"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="±0.005 mm" FontSize="12" FontWeight="Bold" Foreground="#333333"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="实时 PLC 数据监控" FontWeight="Bold" Foreground="#666666" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <TextBlock Text="🔴 实时更新中" FontSize="11" Foreground="#F44336" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                    <TextBlock Text="最后更新: " FontSize="11" Foreground="#999999" VerticalAlignment="Center"/>
                                    <TextBlock Text="14:35:22" FontSize="11" Foreground="#333333" VerticalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <ListView Grid.Row="1" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="15" Margin="10" 
                                            BorderBrush="#E0E0E0" BorderThickness="1" 
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding TagName}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" FontSize="10" Foreground="#999999" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            
                                            <Border Grid.Column="1" Background="#E3F2FD" CornerRadius="4" Padding="15,10" Margin="0,0,15,0">
                                                <StackPanel>
                                                    <TextBlock Text="当前值" FontSize="10" Foreground="#1976D2"/>
                                                    <TextBlock Text="{Binding TagValue}" FontSize="16" FontWeight="Bold" Foreground="#1976D2" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            
                                            <Border Grid.Column="2" CornerRadius="4" Padding="15,10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Quality}" Value="True">
                                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Quality}" Value="False">
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="数据质量" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Quality}" Value="True">
                                                                        <Setter Property="Foreground" Value="#388E3C"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Quality}" Value="False">
                                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,3,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="正常"/>
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Quality}" Value="False">
                                                                        <Setter Property="Text" Value="异常"/>
                                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
                
                <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10">
                            <TextBlock Text="设备组件拆解" FontWeight="Bold" Foreground="#666666"/>
                        </Border>
                        
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Border Grid.Row="0" Background="#F5F5F5" Padding="15,10">
                                        <TextBlock Text="组件列表" FontWeight="Bold" FontSize="12" Foreground="#666666"/>
                                    </Border>
                                    
                                    <ListView Grid.Row="1" BorderThickness="0">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10" Margin="5" 
                                                        BorderBrush="#E0E0E0" BorderThickness="1" 
                                                        CornerRadius="4"
                                                        Background="{Binding CanDisassemble, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#E8F5E9;#F5F5F5'}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <TextBlock Grid.Column="0" Text="🔧" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding ComponentName}" FontWeight="Bold" FontSize="12"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="拆解顺序: " FontSize="10" Foreground="#999999"/>
                                                                <TextBlock Text="{Binding DisassembleOrder}" FontSize="10" Foreground="#333333"/>
                                                            </StackPanel>
                                                            <TextBlock FontSize="10">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="✅ 可拆解"/>
                                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding CanDisassemble}" Value="False">
                                                                                <Setter Property="Text" Value="❌ 不可拆解"/>
                                                                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Border>
                            
                            <Border Grid.Column="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Border Grid.Row="0" Background="#F5F5F5" Padding="15,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="拆解步骤" FontWeight="Bold" FontSize="12" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                <TextBlock Text="步骤 1 / 5" FontSize="11" Foreground="#999999" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="⬅️ 上一步" Style="{StaticResource ActionButtonStyle}" Background="#9E9E9E" Margin="0,0,10,0"/>
                                                <Button Content="➡️ 下一步" Style="{StaticResource ActionButtonStyle}" Background="#2196F3" Margin="0,0,10,0"/>
                                                <Button Content="🔄 重置" Style="{StaticResource ActionButtonStyle}" Background="#FF9800"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    
                                    <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <StackPanel>
                                            <TextBlock Text="🔧" FontSize="80" HorizontalAlignment="Center"/>
                                            <TextBlock Text="设备拆解 3D 视图区域" FontSize="18" Foreground="#666666" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                            <TextBlock Text="(将在此处展示设备拆解动画)" FontSize="12" Foreground="#999999" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                            
                                            <Border Margin="0,30,0,0" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="当前步骤详情" FontSize="14" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="步骤 1: 拆卸主轴护罩" FontSize="16" FontWeight="Bold" Foreground="#2196F3" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                                    <TextBlock Text="使用内六角扳手拧下护罩固定螺丝，然后轻轻取下护罩。" 
                                                               FontSize="12" Foreground="#666666" 
                                                               HorizontalAlignment="Center" Margin="0,10,0,0"
                                                               TextWrapping="Wrap" MaxWidth="400"/>
                                                    <TextBlock Text="⚠️ 注意：护罩下方有连接线，取下时请注意保护。" 
                                                               FontSize="11" Foreground="#FF9800" 
                                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <Border Grid.Row="2" Background="#F8F9FA" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="设备状态: " Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="运行中" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                
                <TextBlock Text="  |  运行时间: " Margin="20,0,5,0" Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="2小时 35分钟" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
                
                <TextBlock Text="  |  当前产量: " Margin="20,0,5,0" Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="125 件" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
                
                <TextBlock Text="  |  效率: " Margin="20,0,5,0" Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="92.5%" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
