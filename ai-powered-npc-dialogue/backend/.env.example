# LLM提供商配置
# 可选值: volcengine (火山引擎豆包) 或 ollama (本地模型)
LLM_PROVIDER=volcengine

# 火山引擎豆包模型配置
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_ENDPOINT_ID=doubao-seed-2-0-code-preview-260215

# Ollama配置 (本地模型)
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama2

# CORS配置 (允许的前端地址)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://frontend:3000"]

# 数据库配置
# DATABASE_URL=sqlite:///./data/npc_dialogue.db

# RAG配置
# KNOWLEDGE_BASE_PATH=./data/knowledge
# VECTOR_STORE_PATH=./data/vector_store
