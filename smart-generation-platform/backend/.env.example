# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./smart_platform.db

# AI模型API配置
# OpenAI API（用于LangChain NL2SQL）
OPENAI_API_KEY=your-openai-api-key

# 百度ERNIE-Music API（用于音乐生成）
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key

# 昆仑万维SkyMusic API（备选音乐生成）
KUNLUN_API_KEY=your-kunlun-api-key

# ControlNet/图像生成模型配置（本地模型或API）
# 如果使用本地ControlNet模型，配置模型路径
# CONTROLNET_MODEL_PATH=./models/controlnet
# 如果使用API服务
# CONTROLNET_API_URL=http://localhost:7860

# 服务器配置
HOST=0.0.0.0
PORT=8000
