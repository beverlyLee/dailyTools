# OpenAI API配置
# 请替换为您的实际API Key
OPENAI_API_KEY=your-openai-api-key-here

# 模型配置
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM参数配置
MAX_TOKENS=4000
TEMPERATURE=0.7

# Flask服务配置
# 注意：macOS上端口5000通常被AirPlay Receiver占用
# 默认使用5001端口
FLASK_APP=app.py
FLASK_DEBUG=True
FLASK_PORT=5001
FLASK_HOST=0.0.0.0

# 数据存储路径
CHROMA_PERSIST_DIRECTORY=./data/vector_store
FEEDBACK_STORAGE_PATH=./data/feedbacks.json
PROMPT_TEMPLATES_PATH=./prompts
