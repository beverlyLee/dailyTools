{
  "name": "@edge-perception/voice-wakeup",
  "version": "1.0.0",
  "description": "Edge-side voice wakeup detection library with VAD (Voice Activity Detection) and WebAssembly. Features: ring buffer audio processing, energy-based VAD, keyword spotting, JavaScript callback support.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src/js",
    "pkg",
    "README.md"
  ],
  "scripts": {
    "build:rust": "wasm-pack build --target web --out-dir pkg --out-name edge_voice_wakeup",
    "build:rust:simd": "RUSTFLAGS=\"-C target-feature=+simd128\" wasm-pack build --target web --out-dir pkg-simd --out-name edge_voice_wakeup",
    "build:js": "rollup -c",
    "build": "npm run build:rust && npm run build:js",
    "dev": "rollup -c -w",
    "clean": "rm -rf dist pkg pkg-simd",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "voice-wakeup",
    "wake-word",
    "keyword-spotting",
    "vad",
    "voice-activity-detection",
    "audio-processing",
    "webassembly",
    "wasm",
    "rust",
    "edge-computing",
    "ring-buffer",
    "dsp",
    "speech-recognition"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/edge-perception-libs.git",
    "directory": "packages/voice-wakeup"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-copy": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@edge-perception/common": "^1.0.0"
  }
}
