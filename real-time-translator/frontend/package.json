    "@dcloudio/uni-stacktracey": "3.0.0-4010520240507001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4010520240507001",
    "@types/node": "^20.11.5",
    "@vue/runtime-core": "^3.4.21",
    "typescript": "^5.3.3",
    "vite": "5.2.8",
    "vue-tsc": "^2.0.6"
  }
}
