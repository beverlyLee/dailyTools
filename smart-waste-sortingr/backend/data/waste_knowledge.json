    "可回收物": {
      "description": "适宜回收和资源利用的垃圾，包括纸类、塑料、玻璃、金属、织物等。",
      "color": "蓝色",
      "disposal_guide": "轻投轻放，清洁干燥，避免污染；废纸尽量平整；立体包装物请清空内容物，清洁后压扁投放；有尖锐边角的，应包裹后投放。",
      "examples": ["纸类", "塑料", "玻璃", "金属", "织物", "电器电子产品"]
    },
    "厨余垃圾": {
      "description": "日常生活产生的易腐性垃圾，包括剩菜剩饭、瓜皮果核、茶渣等。",
      "color": "绿色",
      "disposal_guide": "纯流质的食物垃圾，如牛奶等，应直接倒进下水口；有包装物的厨余垃圾应将包装物去除后分类投放，包装物请投放到对应的可回收物或其他垃圾容器。",
      "examples": ["剩菜剩饭", "瓜皮果核", "茶渣", "蛋壳", "骨头"]
    },
    "有害垃圾": {
      "description": "对人体健康或自然环境造成直接或潜在危害的垃圾，需要特殊安全处理。",
      "color": "红色",
      "disposal_guide": "投放时请注意轻放；易破损的请连带包装或包裹后轻放；如易挥发，请密封后投放。",
      "examples": ["废电池", "废灯管", "废药品", "废油漆", "废温度计"]
    },
    "其他垃圾": {
      "description": "除上述垃圾之外的其他生活垃圾，采用焚烧或填埋方式处理。",
      "color": "灰色或黑色",
      "disposal_guide": "尽量沥干水分；难以辨识类别的生活垃圾投入其他垃圾容器内。",
      "examples": ["餐巾纸", "尿不湿", "烟蒂", "陶瓷", "贝壳"]
    }
  },
